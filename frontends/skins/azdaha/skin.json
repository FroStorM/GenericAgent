    "walk": {
      "file": "walk_sheet.png",
      "loop": true,
      "sprite": { "frameWidth": 150, "frameHeight": 150, "frameCount": 4, "columns": 4, "fps": 10 }
    },
    "attack": {
      "file": "attack_sheet.png",
      "loop": false,
      "sprite": { "frameWidth": 150, "frameHeight": 150, "frameCount": 4, "columns": 4, "fps": 12 }
    },
    "hurt": {
      "file": "hurt_sheet.png",
      "loop": false,
      "sprite": { "frameWidth": 150, "frameHeight": 150, "frameCount": 4, "columns": 4, "fps": 10 }
